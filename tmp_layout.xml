<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#A6000000">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="24dp">

        <LinearLayout
            android:id="@+id/card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#000000"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/titleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="12dp"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Match By:"
                android:textColor="#ffffff"
                android:textSize="12sp"
                android:paddingBottom="4dp" />

            <Spinner
                android:id="@+id/spinMatchType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#FFFFFF"

                android:layout_marginBottom="12dp"
                android:spinnerMode="dropdown" />

            <TextView
                android:id="@+id/descText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="16dp"
                android:textColor="#FFFFFF"
                android:textIsSelectable="true"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/commentInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. Hide explore tab"
                android:singleLine="true"
                android:textColor="#FFFFFF"
                android:textColorHint="#FFFFFF"
                android:textSize="14sp" />

            <!-- Options toggle -->
            <TextView
                android:id="@+id/optionsToggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"
                android:text="▶ Options"
                android:textColor="#33B5E5"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/optionsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Action mode -->
                <CheckBox
                    android:id="@+id/chkPressBack"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="#33B5E5"
                    android:text="Press back instead of overlay"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <!-- Block touches -->
                <CheckBox
                    android:id="@+id/chkBlockTouches"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="#33B5E5"
                    android:checked="true"
                    android:text="Block touches on overlay"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <!-- Match by text content -->
                <CheckBox
                    android:id="@+id/chkMatchByText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="#33B5E5"
                    android:text="Match by text content (fuzzy)"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <!-- Match by description content -->
                <CheckBox
                    android:id="@+id/chkMatchByDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="#33B5E5"
                    android:text="Match by description (fuzzy)"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <!-- Block only if another view is absent -->
                <CheckBox
                    android:id="@+id/chkRequireAbsent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="#33B5E5"
                    android:text="Only block if a view is absent"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/inputAbsentViewId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Absent view ID (e.g. com.app:id/nav)"
                    android:singleLine="true"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#888888"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <!-- Block parent layout -->
                <CheckBox
                    android:id="@+id/chkBlockLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="#33B5E5"
                    android:text="Block entire parent layout"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <!-- Match children content -->
                <CheckBox
                    android:id="@+id/chkMatchChildren"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="#33B5E5"
                    android:text="Only block if children match"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/inputMatchChildren"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Child text to match (e.g. Sponsored)"
                    android:singleLine="true"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#888888"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <!-- Clickable filter -->
                <CheckBox
                    android:id="@+id/chkClickableOnly"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="#33B5E5"
                    android:text="Only match clickable elements"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="horizontal"
                android:paddingTop="16dp">

                <Button
                    android:id="@+id/cancelBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="Cancel"
                    android:textAllCaps="false"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/confirmBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="Confirm"
                    android:textAllCaps="false"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
