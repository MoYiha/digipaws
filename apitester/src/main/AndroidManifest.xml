<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Needed on Android 11+ so we can see and bind Curbox's exported API. -->
    <queries>
        <intent>
            <action android:name="neth.iecal.curbox.api.BIND" />
        </intent>
        <intent>
            <action android:name="neth.iecal.curbox.api.REQUEST_PERMISSION" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:label="Curbox API Tester"
        android:supportsRtl="true"
        android:theme="@style/Theme.Material3.DayNight.NoActionBar">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
